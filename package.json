{
  "name": "costa-brava-trip-planner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Costa Brava Trip Planner — a real-places-only planning PWA for a 6-night Empordà coast trip.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:icons": "node scripts/gen-icons.mjs",
    "check:keys": "node scripts/check-keys.mjs",
    "check:amadeus": "node scripts/check-amadeus.mjs",
    "check:serpapi": "node scripts/check-serpapi.mjs",
    "proxy": "node server/price-proxy.mjs"
  },
  "dependencies": {
    "@vis.gl/react-google-maps": "^1.5.5",
    "localforage": "^1.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.20",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^2.1.9"
  }
}
